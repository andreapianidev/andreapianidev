  <!-- PROBLEMA → SOLUZIONE -->
  <section style="padding: 5rem 0; background: #0a0a0a;">
    <div class="container">
      <div class="text-center mb-5">
        <h2 class="display-4 mb-3">Ti riconosci in questi problemi?</h2>
        <p style="color: #aaa; max-width: 700px; margin: 0 auto;">Ogni idraulico, elettricista, termoidraulico e artigiano su chiamata in Italia perde ore in burocrazia e contestazioni. JobMate Pro le elimina.</p>
      </div>
      <div class="row">
        <div class="col-lg-6">
          <h3 class="h4 mb-4" style="color: #ff9800;">Senza un'app dedicata:</h3>
          <div style="background: #1a1a1a; padding: 2rem; border-radius: 15px; border-left: 4px solid #ff9800;">
            <ul style="list-style: none; padding: 0; margin: 0; line-height: 2.5;">
              <li>❌ <strong>Bolle cartacee perse</strong>: copia smarrita, contestazioni, fattura non emettibile</li>
              <li>❌ <strong>Preventivi a voce</strong>: cliente "ah, non mi avevi detto questo prezzo"</li>
              <li>❌ <strong>Foto sparse sul telefono</strong>: niente prova del lavoro fatto</li>
              <li>❌ <strong>Percorsi giornalieri caotici</strong>: ore in macchina invece che in cantiere</li>
              <li>❌ <strong>Storico cliente in testa</strong>: "che caldaia ha quel cliente?" mai certo</li>
              <li>❌ <strong>Magazzino furgone misterioso</strong>: ricambi finiti, viaggi extra</li>
              <li>❌ <strong>Fatture mese dopo</strong>: incassi tardivi, pagamenti dimenticati</li>
            </ul>
          </div>
        </div>
        <div class="col-lg-6 mt-4 mt-lg-0">
          <h3 class="h4 mb-4" style="color: #4caf50;">Con JobMate Pro:</h3>
          <div style="background: #1a1a1a; padding: 2rem; border-radius: 15px; border-left: 4px solid #4caf50;">
            <ul style="list-style: none; padding: 0; margin: 0; line-height: 2.5;">
              <li>✅ <strong>Bolla digitale firmata sul posto</strong>: PDF al cliente via WhatsApp subito</li>
              <li>✅ <strong>Preventivi PDF in 30 secondi</strong>: tariffario, ricambi, IVA, brand professionale</li>
              <li>✅ <strong>Foto pre/post geolocalizzate</strong>: prova certa del lavoro eseguito</li>
              <li>✅ <strong>Percorso giornaliero ottimizzato</strong>: -25% di km percorsi al giorno</li>
              <li>✅ <strong>Anagrafica impianti completa</strong>: caldaia, quadro, scheda con foto</li>
              <li>✅ <strong>Magazzino furgone tracciato</strong>: cosa hai a bordo, sempre aggiornato</li>
              <li>✅ <strong>Pagamento istantaneo POS Stripe</strong>: incasso al termine intervento</li>
            </ul>
          </div>
        </div>
      </div>

      <!-- STATISTICHE -->
      <div class="row mt-5 text-center g-4">
        <div class="col-6 col-md-3">
          <div style="background: #1a1a1a; padding: 2rem; border-radius: 15px; border-top: 3px solid #ff9800;">
            <div style="font-size: 2.5rem; font-weight: bold; color: #ff9800;">+12h</div>
