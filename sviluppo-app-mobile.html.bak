  <!-- SETTORI VERTICALI -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="section-eyebrow">Settori Serviti</span>
        <h2 class="section-title">App Mobile per <span style="color: var(--brand-primary);">ogni industria</span></h2>
        <p class="section-lead">Ho sviluppato app per startup e PMI in decine di settori. Esperienza specifica = decisioni più rapide e risultati migliori.</p>
      </div>

      <div class="row g-4">
        <div class="col-6 col-md-4 col-lg-3">
          <div class="sector-card">
            <span class="sector-emoji">🏥</span>
            <h5>Health &amp; Fitness</h5>
            <p>HealthKit, Google Fit, AI personal trainer, telemedicine</p>
          </div>
        </div>
        <div class="col-6 col-md-4 col-lg-3">
          <div class="sector-card">
