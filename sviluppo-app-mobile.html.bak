              <td class="stars-good">⭐⭐⭐⭐ Ottima<br><small>Rendering Skia</small></td>
              <td class="stars-mid">⭐⭐⭐ Buona<br><small>JS bridge</small></td>
            </tr>
            <tr>
              <td><strong>UX Nativa</strong></td>
              <td class="stars-good">⭐⭐⭐⭐⭐ Perfetta</td>
              <td class="stars-good">⭐⭐⭐⭐ Molto buona</td>
              <td class="stars-mid">⭐⭐⭐ Buona</td>
            </tr>
            <tr>
              <td><strong>Tempo sviluppo</strong></td>
              <td class="stars-bad">Più lungo<br><small>2 codebase</small></td>
              <td class="stars-good">Veloce<br><small>1 codebase</small></td>
              <td class="stars-good">Veloce<br><small>1 codebase</small></td>
            </tr>
            <tr>
              <td><strong>Costo</strong></td>
              <td class="stars-bad">€€€€<br><small>2 team</small></td>
              <td class="stars-good">€€<br><small>Riuso 95%</small></td>
              <td class="stars-good">€€<br><small>Riuso 90%</small></td>
            </tr>
            <tr>
              <td><strong>Accesso API device</strong></td>
              <td class="stars-good">Completo</td>
              <td class="stars-good">Completo</td>
              <td class="stars-mid">Plugin custom</td>
            </tr>
            <tr>
              <td><strong>Dimensione app</strong></td>
              <td class="stars-good">Ottimale</td>
              <td class="stars-mid">+4-8MB engine</td>
              <td class="stars-mid">+8-12MB bundle</td>
            </tr>
            <tr>
              <td><strong>Ideale per</strong></td>
              <td>🎯 Fintech, health<br>🎯 Gaming, AR/VR<br>🎯 UX critica</td>
              <td>🎯 MVP startup<br>🎯 Budget medio<br>🎯 UI custom</td>
              <td>🎯 Team React<br>🎯 App content-based<br>🎯 Prototipo veloce</td>
            </tr>
          </tbody>
        </table>
      </div>

