  <script>
    // Form submission with loading state and toast notification
    document.querySelectorAll('form[action*="formspree"]').forEach(form => {
      form.addEventListener('submit', function(e) {
        const btn = this.querySelector('button[type="submit"]');
        if (btn && window.AppUtils) {
          window.AppUtils.setButtonLoading(btn, true);
        }
        if (window.AppUtils) {
          window.AppUtils.trackEvent('Form', 'Submit', 'Contact Form Mobile');
        }
        setTimeout(() => {
          if (btn && window.AppUtils) {
            window.AppUtils.setButtonLoading(btn, false);
          }
          if (window.Toast) {
            window.Toast.success('Messaggio inviato! Ti risponderò entro 24h', 'Grazie!');
          }
        }, 1000);
      });
    });

    // Track CTA clicks
    document.querySelectorAll('a[href*="preventivo-app"], a[href*="wa.me"], a[href^="tel:"]').forEach(link => {
      link.addEventListener('click', () => {
        if (window.AppUtils) {
          const type = link.href.includes('wa.me') ? 'WhatsApp'
                    : link.href.startsWith('tel:') ? 'Phone'
                    : 'Quote';
          window.AppUtils.trackEvent('CTA', 'Click', `Mobile_${type}`);
        }
      });
    });
  </script>

