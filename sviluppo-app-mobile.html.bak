  <!-- Schema.org FAQPage -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Quanto costa sviluppare un'app mobile in Italia nel 2026?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Il costo varia in base a complessità e tecnologia: MVP startup da €8.000 a €15.000 (4-8 settimane), app media cross-platform da €15.000 a €25.000 (2-3 mesi), app native iOS+Android da €25.000 a €50.000+ (3-5 mesi), app complesse fintech/health da €40.000 a €80.000+ (5-6 mesi). Preventivo gratuito personalizzato in 24 ore."
        }
      },
      {
        "@type": "Question",
        "name": "È meglio sviluppare app native o cross-platform?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Dipende dal caso: Native (Swift/Kotlin) per performance critiche, gaming, fintech, health, budget €25k+. Cross-Platform (Flutter/React Native) per MVP rapidi, budget €10-20k, time-to-market critico, app content-based. Per startup consiglio Flutter per MVP, poi native se scali."
        }
      },
      {
        "@type": "Question",
        "name": "Quanto tempo serve per sviluppare un'app mobile?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Timeline tipiche: MVP startup 4-8 settimane, app semplice 1-2 mesi, app media 2-4 mesi, app complessa 4-6+ mesi. Fattori: numero feature, design custom, backend, native vs cross-platform, integrazioni esterne."
        }
      },
      {
        "@type": "Question",
        "name": "Pubblichi l'app sull'App Store e Google Play?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Sì, gestisco pubblicazione completa: setup developer account Apple/Google, asset grafici, descrizioni ASO ottimizzate, screenshot per ogni device, privacy policy GDPR, gestione rejection review, rollout progressivo. App live tipicamente in 3-7 giorni da submit."
        }
      },
      {
        "@type": "Question",
        "name": "Offri garanzia sul codice dell'app?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Sì: bug fix gratuiti 60 giorni post-lancio, codice pulito con best practices e test coverage >70%, repository GitHub privato 100% proprietà cliente, documentazione tecnica completa, zero vendor lock-in."
        }
      },
      {
        "@type": "Question",
        "name": "Quanto costa mantenere un'app dopo il lancio?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Budget annuale tipico 15-20% del costo sviluppo iniziale. Costi fissi: hosting €20-200/mese, Apple Developer €99/anno, Google Play $25 una-tantum. Pacchetti maintenance: Basic €200/mese, Standard €500/mese, Premium €1000+/mese."
        }
      },
      {
        "@type": "Question",
        "name": "Accetti pagamenti rateizzati?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Sì, pagamenti milestone-based: 30% upfront, 30% design+backend, 30% pre-lancio, 10% post-lancio. Progetti piccoli 50%+50%. Metodi: bonifico, PayPal, Stripe, fattura con P.IVA. Per startup early-stage valuto equity option."
        }
      },
      {
        "@type": "Question",
        "name": "Come proteggi la mia idea?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "NDA (Non-Disclosure Agreement) firmabile prima di ogni call. Policy interna zero condivisione. Codice sorgente 100% proprietà cliente, repository GitHub privato. 15+ anni reputazione mai violata confidenzialità."
        }
      }
    ]
  }
  </script>

  <!-- Schema.org HowTo -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "Come sviluppare un'app mobile professionale",
    "description": "Processo completo in 7 step per sviluppare un'app mobile iOS e Android dalla idea alla pubblicazione sugli store.",
    "totalTime": "P90D",
    "estimatedCost": {
      "@type": "MonetaryAmount",
      "currency": "EUR",
      "value": "15000"
    },
    "step": [
      {"@type": "HowToStep", "position": 1, "name": "Discovery e Analisi", "text": "Kickoff meeting, analisi competitori, definizione MVP, target user personas, scelta stack tecnologico. Durata 3-5 giorni."},
      {"@type": "HowToStep", "position": 2, "name": "UX/UI Design", "text": "Wireframes, mockup high-fidelity, prototipo interattivo Figma, design system riutilizzabile. Durata 1-2 settimane."},
      {"@type": "HowToStep", "position": 3, "name": "Setup Backend e API", "text": "Scelta stack (Node.js/Firebase), architettura API REST o GraphQL, database design, storage media, push notifications. Durata 1 settimana."},
      {"@type": "HowToStep", "position": 4, "name": "Sviluppo Mobile App", "text": "Codifica iOS (Swift/SwiftUI) + Android (Kotlin/Compose) o cross-platform (Flutter), integrazioni, testing unitario, CI/CD. Durata 4-10 settimane."},
      {"@type": "HowToStep", "position": 5, "name": "Testing e QA", "text": "Test funzionali, multi-device, performance, sicurezza OWASP Mobile Top 10, UAT con utenti reali. Durata 1-2 settimane."},
      {"@type": "HowToStep", "position": 6, "name": "Pubblicazione Stores", "text": "Setup developer account, store listing ASO, privacy policy GDPR, submit Apple/Google, rollout progressivo. Durata 3-7 giorni."},
      {"@type": "HowToStep", "position": 7, "name": "Supporto Post-Lancio", "text": "Monitoring 24/7, bug fix prioritari, aggiornamenti OS, analytics e report mensili, feature updates. Ongoing."}
    ]
  }
  </script>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="assets/bootstrap/css/bootstrap.min.css">
  <link rel="stylesheet" href="navbar-fix.css">
  <link rel="stylesheet" href="animations.css">
  <link rel="stylesheet" href="assets/theme/css/style.css">
  <link rel="stylesheet" href="utilities.css">
  <link rel="stylesheet" href="dark-mode.css">
  <link rel="preload" href="https://fonts.googleapis.com/css?family=Jost:100,200,300,400,500,600,700,800,900&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'">

  <style>
    :root {
      --brand-primary: #6366f1;
      --brand-secondary: #8b5cf6;
      --brand-accent: #ec4899;
      --dark-bg: #060814;
      --dark-card: #0f1220;
      --dark-card-hover: #161a2e;
      --border-subtle: #1f2337;
      --text-primary: #ffffff;
      --text-secondary: #a8b0d1;
      --success: #10b981;
      --warning: #f59e0b;
      --danger: #ef4444;
    }

    body {
      background-color: var(--dark-bg);
      color: var(--text-primary);
      font-family: 'Jost', sans-serif;
      overflow-x: hidden;
    }

    h1, h2, h3, h4, h5, h6 { font-weight: 700; letter-spacing: -0.02em; }
    h1 { font-size: clamp(2.2rem, 5vw, 4rem); line-height: 1.1; }
    h2 { font-size: clamp(1.8rem, 3.5vw, 2.8rem); line-height: 1.2; }
    h3 { font-size: clamp(1.3rem, 2vw, 1.8rem); line-height: 1.3; }

    /* TRUST BAR */
    .trust-bar {
      background: linear-gradient(90deg, rgba(99,102,241,0.1) 0%, rgba(139,92,246,0.1) 100%);
      border-bottom: 1px solid var(--border-subtle);
      padding: 0.6rem 0;
      font-size: 0.85rem;
      color: var(--text-secondary);
    }
    .trust-bar strong { color: var(--text-primary); }

    /* HERO */
    .hero-wrap {
      position: relative;
      padding: 5rem 0 6rem;
      overflow: hidden;
      background: radial-gradient(ellipse at top left, rgba(99,102,241,0.25), transparent 50%),
                  radial-gradient(ellipse at bottom right, rgba(236,72,153,0.18), transparent 50%),
                  radial-gradient(ellipse at center, rgba(139,92,246,0.12), transparent 60%),
                  var(--dark-bg);
    }
    .hero-wrap::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(99,102,241,0.06) 1px, transparent 1px),
        linear-gradient(90deg, rgba(99,102,241,0.06) 1px, transparent 1px);
      background-size: 60px 60px;
      mask-image: radial-gradient(ellipse at center, black 40%, transparent 80%);
      pointer-events: none;
    }
    .hero-wrap > .container { position: relative; z-index: 2; }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: rgba(99,102,241,0.15);
      border: 1px solid rgba(99,102,241,0.4);
      color: #c7d2fe;
      padding: 0.4rem 1rem;
      border-radius: 999px;
      font-size: 0.85rem;
      margin-bottom: 1.5rem;
      backdrop-filter: blur(10px);
    }
    .hero-badge .pulse-dot {
      width: 8px; height: 8px;
      background: var(--success);
      border-radius: 50%;
      box-shadow: 0 0 0 0 rgba(16,185,129,0.7);
      animation: pulsedot 2s infinite;
    }
    @keyframes pulsedot {
      0% { box-shadow: 0 0 0 0 rgba(16,185,129,0.7); }
      70% { box-shadow: 0 0 0 10px rgba(16,185,129,0); }
      100% { box-shadow: 0 0 0 0 rgba(16,185,129,0); }
    }

    .hero-title .gradient-text {
      background: linear-gradient(135deg, #818cf8 0%, #c084fc 50%, #f472b6 100%);
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .hero-subtitle {
      font-size: clamp(1rem, 1.3vw, 1.2rem);
      color: var(--text-secondary);
      line-height: 1.7;
      margin-bottom: 2rem;
      max-width: 620px;
    }

    .tech-badge {
      display: inline-block;
      background: rgba(255,255,255,0.06);
      border: 1px solid var(--border-subtle);
      padding: 0.4rem 0.9rem;
      border-radius: 999px;
      margin: 0.25rem 0.2rem 0.25rem 0;
      font-size: 0.85rem;
      color: var(--text-secondary);
      transition: all 0.25s;
    }
    .tech-badge:hover {
      background: rgba(99,102,241,0.15);
      border-color: var(--brand-primary);
      color: #fff;
      transform: translateY(-2px);
    }

    .btn-primary-gradient {
      background: linear-gradient(135deg, var(--brand-primary) 0%, var(--brand-secondary) 100%);
      color: white !important;
      border: none;
      padding: 0.9rem 2rem;
      border-radius: 12px;
      font-weight: 600;
      font-size: 1rem;
      box-shadow: 0 10px 30px -10px rgba(99,102,241,0.6);
      transition: all 0.3s;
      position: relative;
      overflow: hidden;
    }
    .btn-primary-gradient:hover {
      transform: translateY(-3px);
      box-shadow: 0 15px 40px -10px rgba(99,102,241,0.8);
      color: white;
    }
    .btn-primary-gradient::after {
      content: '';
      position: absolute;
      top: 0; left: -100%;
      width: 100%; height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
      transition: left 0.6s;
    }
    .btn-primary-gradient:hover::after { left: 100%; }

    .btn-ghost {
      background: rgba(255,255,255,0.05);
      color: white !important;
      border: 1px solid rgba(255,255,255,0.15);
      padding: 0.9rem 2rem;
      border-radius: 12px;
      font-weight: 600;
      font-size: 1rem;
      transition: all 0.3s;
      backdrop-filter: blur(10px);
    }
    .btn-ghost:hover {
      background: rgba(255,255,255,0.1);
      border-color: rgba(255,255,255,0.3);
      transform: translateY(-3px);
      color: white;
    }

    /* HERO STATS CARD */
    .hero-stats {
      background: linear-gradient(145deg, rgba(15,18,32,0.8), rgba(20,24,42,0.6));
      backdrop-filter: blur(20px);
      border: 1px solid var(--border-subtle);
      border-radius: 24px;
      padding: 2rem;
      position: relative;
      overflow: hidden;
    }
    .hero-stats::before {
      content: '';
      position: absolute;
      top: -1px; left: -1px; right: -1px; bottom: -1px;
      background: linear-gradient(135deg, var(--brand-primary), var(--brand-accent));
      border-radius: 24px;
      z-index: -1;
      opacity: 0.3;
    }
    .stat-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.1rem 0;
      border-bottom: 1px solid var(--border-subtle);
    }
    .stat-row:last-child { border: none; padding-bottom: 0; }
    .stat-row:first-child { padding-top: 0; }
    .stat-value {
      font-size: 2rem;
      font-weight: 800;
      background: linear-gradient(135deg, #818cf8, #f472b6);
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .stat-label { color: var(--text-secondary); font-size: 0.95rem; }

    /* SOCIAL PROOF STRIP */
    .social-strip {
      background: #0a0d1a;
      padding: 2.5rem 0;
      border-top: 1px solid var(--border-subtle);
      border-bottom: 1px solid var(--border-subtle);
    }
    .rating-big {
      display: flex;
      align-items: center;
      gap: 1rem;
      justify-content: center;
    }
    .rating-stars {
      color: #fbbf24;
      font-size: 1.5rem;
      letter-spacing: 2px;
    }

    /* SECTION BASE */
    .section {
      padding: 5rem 0;
      position: relative;
    }
    .section-alt { background: #0a0d1a; }
    .section-head { margin-bottom: 3.5rem; text-align: center; }
    .section-eyebrow {
      display: inline-block;
      color: var(--brand-primary);
      font-weight: 600;
      font-size: 0.9rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      margin-bottom: 0.8rem;
    }
    .section-title { margin-bottom: 1rem; }
    .section-lead {
      color: var(--text-secondary);
      font-size: 1.1rem;
      max-width: 720px;
      margin: 0 auto;
    }

    /* FEATURE CARDS */
    .feature-card {
      background: var(--dark-card);
      border: 1px solid var(--border-subtle);
      border-radius: 20px;
      padding: 2rem;
      height: 100%;
      transition: all 0.35s;
      position: relative;
      overflow: hidden;
    }
    .feature-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0;
      width: 100%; height: 3px;
      background: linear-gradient(90deg, var(--brand-primary), var(--brand-accent));
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.4s;
    }
    .feature-card:hover {
      background: var(--dark-card-hover);
      border-color: var(--brand-primary);
      transform: translateY(-6px);
      box-shadow: 0 20px 40px -20px rgba(99,102,241,0.3);
    }
    .feature-card:hover::before { transform: scaleX(1); }
    .feature-icon {
      width: 56px;
      height: 56px;
      border-radius: 14px;
      background: linear-gradient(135deg, rgba(99,102,241,0.2), rgba(139,92,246,0.1));
      border: 1px solid rgba(99,102,241,0.3);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.8rem;
      margin-bottom: 1.2rem;
    }
    .feature-card h4 { margin-bottom: 0.7rem; }
    .feature-card p { color: var(--text-secondary); margin-bottom: 0; line-height: 1.6; }

    /* VERTICAL SECTORS */
    .sector-card {
      background: var(--dark-card);
      border: 1px solid var(--border-subtle);
      border-radius: 18px;
      padding: 1.8rem;
      text-align: center;
      height: 100%;
      transition: all 0.3s;
      cursor: default;
    }
    .sector-card:hover {
      transform: translateY(-4px);
      border-color: var(--brand-primary);
      background: linear-gradient(145deg, var(--dark-card-hover), var(--dark-card));
    }
    .sector-emoji { font-size: 2.8rem; margin-bottom: 0.8rem; display: block; }
    .sector-card h5 { margin-bottom: 0.5rem; font-size: 1.1rem; }
    .sector-card p { color: var(--text-secondary); font-size: 0.9rem; margin-bottom: 0; }

    /* PROCESS */
    .process-timeline {
      position: relative;
      padding-left: 2rem;
    }
    .process-timeline::before {
      content: '';
      position: absolute;
      left: 30px; top: 0; bottom: 0;
      width: 2px;
      background: linear-gradient(180deg, var(--brand-primary), var(--brand-accent) 50%, transparent);
    }
    .process-step {
      position: relative;
      background: var(--dark-card);
      border: 1px solid var(--border-subtle);
      border-radius: 18px;
      padding: 1.8rem 1.8rem 1.8rem 5rem;
      margin-bottom: 1.5rem;
      margin-left: 0;
      transition: all 0.3s;
    }
    .process-step:hover {
      border-color: var(--brand-primary);
      transform: translateX(5px);
    }
    .process-step .step-num {
      position: absolute;
      left: -15px; top: 1.8rem;
      width: 50px; height: 50px;
      background: linear-gradient(135deg, var(--brand-primary), var(--brand-secondary));
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.3rem;
      font-weight: 800;
      box-shadow: 0 0 0 6px var(--dark-bg), 0 8px 20px rgba(99,102,241,0.5);
    }
    .process-step h3 { margin-bottom: 0.4rem; }
    .process-step .step-duration {
      color: var(--brand-primary);
      font-size: 0.85rem;
      font-weight: 600;
      margin-bottom: 1rem;
      display: block;
    }
    .process-step ul { color: var(--text-secondary); line-height: 1.8; padding-left: 1.2rem; }
    .process-step ul li strong { color: #e4e7f5; }
    .process-step .deliverable {
      margin-top: 1rem;
      padding: 0.8rem 1rem;
      background: rgba(16,185,129,0.08);
      border-left: 3px solid var(--success);
      border-radius: 6px;
      font-size: 0.9rem;
      color: #d1fae5;
    }

    /* VS COMPARISON */
    .vs-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
    @media (max-width: 768px) { .vs-grid { grid-template-columns: 1fr; } }
    .vs-card {
      background: var(--dark-card);
      border: 1px solid var(--border-subtle);
      border-radius: 18px;
      padding: 2rem;
    }
    .vs-card.freelance { border-color: var(--success); background: linear-gradient(145deg, rgba(16,185,129,0.05), var(--dark-card)); }
    .vs-card.agency { border-color: var(--border-subtle); opacity: 0.85; }
    .vs-card h4 { margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.7rem; }
    .vs-card ul { list-style: none; padding: 0; }
    .vs-card li {
      padding: 0.6rem 0;
      border-bottom: 1px solid var(--border-subtle);
      display: flex;
      align-items: start;
      gap: 0.7rem;
      color: var(--text-secondary);
    }
    .vs-card li:last-child { border: none; }
    .vs-card li::before { content: ''; flex-shrink: 0; margin-top: 6px; width: 16px; height: 16px; border-radius: 50%; }
    .vs-card.freelance li::before { background: var(--success); box-shadow: 0 0 8px rgba(16,185,129,0.5); }
    .vs-card.agency li::before { background: var(--danger); opacity: 0.6; }

    /* TECH COMPARE TABLE */
    .compare-wrap {
      background: var(--dark-card);
      border: 1px solid var(--border-subtle);
      border-radius: 20px;
      overflow: hidden;
    }
    .compare-wrap table {
      width: 100%;
      margin: 0;
      color: var(--text-primary);
    }
    .compare-wrap th {
      background: linear-gradient(135deg, var(--brand-primary), var(--brand-secondary));
      color: white;
      padding: 1.1rem 0.8rem;
      text-align: center;
      font-weight: 700;
      font-size: 0.95rem;
    }
    .compare-wrap td {
      padding: 1rem 0.8rem;
      border-bottom: 1px solid var(--border-subtle);
      vertical-align: middle;
      font-size: 0.9rem;
    }
    .compare-wrap tr:last-child td { border-bottom: none; }
    .compare-wrap tr:hover td { background: rgba(99,102,241,0.04); }
    .stars-good { color: var(--success); }
    .stars-mid { color: var(--warning); }
    .stars-bad { color: var(--danger); }

    /* CASE STUDY */
    .case-card {
      background: linear-gradient(145deg, var(--dark-card), #080b16);
      border: 1px solid var(--border-subtle);
      border-radius: 24px;
      padding: 2.5rem;
      margin-bottom: 2rem;
      position: relative;
      overflow: hidden;
    }
    .case-card::before {
      content: '';
      position: absolute;
      top: 0; right: 0;
      width: 300px; height: 300px;
      background: radial-gradient(circle, rgba(99,102,241,0.15), transparent 70%);
      transform: translate(100px, -100px);
    }
    .case-tag {
      display: inline-block;
      padding: 0.35rem 0.9rem;
      border-radius: 999px;
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      margin-right: 0.5rem;
      margin-bottom: 0.5rem;
    }
    .tag-health { background: rgba(16,185,129,0.15); color: #6ee7b7; border: 1px solid rgba(16,185,129,0.3); }
    .tag-ecom { background: rgba(20,157,204,0.15); color: #7dd3fc; border: 1px solid rgba(20,157,204,0.3); }
    .tag-fintech { background: rgba(239,68,68,0.15); color: #fca5a5; border: 1px solid rgba(239,68,68,0.3); }
    .tag-tech { background: rgba(99,102,241,0.15); color: #c7d2fe; border: 1px solid rgba(99,102,241,0.3); }
    .case-metrics {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
      gap: 1rem;
      margin-top: 1.5rem;
    }
    .metric-box {
      background: rgba(255,255,255,0.03);
      border: 1px solid var(--border-subtle);
      border-radius: 12px;
      padding: 1.2rem;
      text-align: center;
    }
    .metric-value {
      font-size: 1.8rem;
      font-weight: 800;
      color: var(--success);
      line-height: 1;
    }
    .metric-value.purple { background: linear-gradient(135deg, #a78bfa, #f472b6); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; }
    .metric-label {
      font-size: 0.8rem;
      color: var(--text-secondary);
      margin-top: 0.3rem;
    }

    /* MVP PANEL */
    .mvp-hero {
      background: linear-gradient(135deg, rgba(99,102,241,0.12), rgba(236,72,153,0.08));
      border: 1px solid rgba(99,102,241,0.3);
      border-radius: 24px;
      padding: 3rem;
    }
    .mvp-timeline-item {
      background: var(--dark-card);
      border-left: 4px solid var(--brand-primary);
      padding: 1.2rem 1.5rem;
      border-radius: 8px;
      margin-bottom: 1rem;
    }
    .mvp-timeline-item h5 { color: #fff; margin-bottom: 0.3rem; }
    .mvp-timeline-item p { color: var(--text-secondary); margin-bottom: 0; font-size: 0.95rem; }

    /* TESTIMONIAL */
    .testimonial-card {
      background: var(--dark-card);
      border: 1px solid var(--border-subtle);
      border-radius: 20px;
      padding: 2rem;
      height: 100%;
      position: relative;
      transition: all 0.3s;
    }
    .testimonial-card:hover { border-color: var(--brand-primary); transform: translateY(-4px); }
    .testimonial-card::before {
      content: '"';
      position: absolute;
      top: -10px; left: 1.5rem;
      font-size: 5rem;
      color: var(--brand-primary);
      font-family: Georgia, serif;
      line-height: 1;
      opacity: 0.3;
    }
    .testimonial-stars { color: #fbbf24; margin-bottom: 1rem; }
    .testimonial-text {
      color: #e4e7f5;
      font-size: 1rem;
      line-height: 1.6;
      margin-bottom: 1.5rem;
      font-style: italic;
    }
    .testimonial-author { display: flex; align-items: center; gap: 0.8rem; }
    .testimonial-avatar {
      width: 48px; height: 48px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--brand-primary), var(--brand-accent));
      display: flex; align-items: center; justify-content: center;
      font-weight: 700;
      font-size: 1.1rem;
    }
    .testimonial-author strong { display: block; color: #fff; }
    .testimonial-author small { color: var(--text-secondary); }

    /* FAQ */
    .faq-item {
      background: var(--dark-card);
      border: 1px solid var(--border-subtle);
      border-radius: 16px;
      margin-bottom: 1rem;
      overflow: hidden;
      transition: all 0.3s;
    }
    .faq-item:hover { border-color: rgba(99,102,241,0.5); }
    .faq-item summary {
      padding: 1.3rem 1.5rem;
      cursor: pointer;
      font-weight: 600;
      color: #fff;
      font-size: 1.05rem;
      list-style: none;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
    }
    .faq-item summary::-webkit-details-marker { display: none; }
    .faq-item summary::after {
      content: '+';
      font-size: 1.8rem;
      color: var(--brand-primary);
      font-weight: 300;
      line-height: 1;
      transition: transform 0.3s;
      flex-shrink: 0;
    }
    .faq-item[open] summary::after { transform: rotate(45deg); }
    .faq-body {
      padding: 0 1.5rem 1.5rem;
      color: var(--text-secondary);
      line-height: 1.7;
    }
    .faq-body ul, .faq-body ol { padding-left: 1.2rem; }
    .faq-body strong { color: #e4e7f5; }

    /* FINAL CTA */
    .final-cta {
      background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 50%, #ec4899 100%);
      border-radius: 32px;
      padding: 4rem 3rem;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .final-cta::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image: radial-gradient(circle at 20% 20%, rgba(255,255,255,0.15), transparent 40%),
                         radial-gradient(circle at 80% 80%, rgba(255,255,255,0.1), transparent 40%);
    }
    .final-cta > * { position: relative; z-index: 1; }
    .final-cta h2 { color: white; margin-bottom: 1rem; }
    .final-cta p { color: rgba(255,255,255,0.95); font-size: 1.15rem; }

    .btn-white-solid {
      background: #fff;
      color: #6366f1 !important;
      border: none;
      padding: 1rem 2.2rem;
      border-radius: 12px;
      font-weight: 700;
      font-size: 1.05rem;
      transition: all 0.3s;
      box-shadow: 0 10px 30px -10px rgba(0,0,0,0.4);
    }
    .btn-white-solid:hover { transform: translateY(-3px); box-shadow: 0 15px 40px -10px rgba(0,0,0,0.5); }

    /* STICKY MOBILE CTA */
    .sticky-cta-mobile {
      display: none;
      position: fixed;
      bottom: 0; left: 0; right: 0;
      background: rgba(6,8,20,0.95);
      backdrop-filter: blur(20px);
      border-top: 1px solid var(--border-subtle);
      padding: 0.8rem;
      z-index: 9000;
      gap: 0.5rem;
    }
    .sticky-cta-mobile a {
      flex: 1;
      text-align: center;
      padding: 0.8rem;
      border-radius: 10px;
      font-weight: 600;
      text-decoration: none;
      font-size: 0.9rem;
    }
    .sticky-cta-mobile .sticky-primary {
      background: linear-gradient(135deg, var(--brand-primary), var(--brand-secondary));
      color: white;
    }
    .sticky-cta-mobile .sticky-whatsapp {
      background: #25d366;
      color: white;
    }
    @media (max-width: 768px) {
      .sticky-cta-mobile { display: flex; }
      body { padding-bottom: 70px; }
    }

    /* TECH STACK GRID */
    .tech-stack-card {
      background: var(--dark-card);
      border: 1px solid var(--border-subtle);
      border-radius: 16px;
      padding: 1.8rem;
      height: 100%;
      transition: all 0.3s;
    }
    .tech-stack-card:hover { border-color: var(--brand-primary); transform: translateY(-3px); }
    .tech-stack-card h5 {
      color: var(--brand-primary);
      margin-bottom: 1.2rem;
      font-size: 1rem;
      font-weight: 700;
    }
    .tech-stack-card ul {
      list-style: none;
      padding: 0;
      margin: 0;
      color: var(--text-secondary);
    }
    .tech-stack-card li {
      padding: 0.35rem 0;
      font-size: 0.9rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .tech-stack-card li::before {
      content: '▸';
      color: var(--brand-primary);
      font-weight: bold;
    }

    .navbar-custom {
      background: rgba(6,8,20,0.85);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border-subtle);
      padding: 0.9rem 0;
    }
    .navbar-custom a { color: #ffffff !important; margin: 0 0.8rem; font-weight: 500; }
    .navbar-custom a:hover { color: var(--brand-primary) !important; }

    @media (max-width: 991px) {
      .hero-wrap { padding: 3.5rem 0 4rem; }
      .section { padding: 3.5rem 0; }
      .case-card { padding: 1.8rem; }
      .final-cta { padding: 2.5rem 1.5rem; }
      .process-step { padding-left: 4rem; }
    }
  </style>
</head>

