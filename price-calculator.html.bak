<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="Calcola il costo stimato per lo sviluppo della tua app mobile. Preventivo istantaneo e personalizzato.">
  <meta name="robots" content="index, follow, max-image-preview:large">
  <title>Calcolatore Preventivo App | Andrea Piani</title>

  <meta property="og:title" content="Calcolatore Preventivo App | Andrea Piani">
  <meta property="og:description" content="Calcola il costo stimato per lo sviluppo della tua app mobile. Preventivo istantaneo e personalizzato.">
  <meta property="og:image" content="https://www.andreapiani.com/assets/images/andrea-piani-logo.png">
  <meta property="og:url" content="https://www.andreapiani.com/price-calculator.html">
  <meta property="og:type" content="website">
  <link rel="canonical" href="https://www.andreapiani.com/price-calculator.html" />

  <link rel="stylesheet" href="assets/bootstrap/css/bootstrap.min.css">
  <link rel="stylesheet" href="navbar-fix.css">
  <link rel="stylesheet" href="animations.css">
  <link rel="stylesheet" href="utilities.css">
  <link rel="stylesheet" href="dark-mode.css">

  <style>
    body {
      background: #0a0a0a;
      color: white;
      min-height: 100vh;
    }

    .calculator-container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 2rem 1rem;
    }

    .calculator-header {
      text-align: center;
      margin-bottom: 3rem;
      padding-top: 6rem;
    }

    .calculator-header h1 {
      font-size: 3rem;
      font-weight: bold;
      margin-bottom: 1rem;
      background: linear-gradient(135deg, #149dcc 0%, #0d7a9e 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .calculator-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
      margin-bottom: 3rem;
    }

    @media (max-width: 768px) {
      .calculator-grid {
        grid-template-columns: 1fr;
      }
    }

    .calculator-section {
      background: #1a1a1a;
      border-radius: 16px;
      padding: 2rem;
      border: 1px solid #333;
    }

    .calculator-section h3 {
      color: #149dcc;
      margin-bottom: 1.5rem;
      font-size: 1.5rem;
    }

    .option-group {
      margin-bottom: 2rem;
    }

    .option-label {
      display: block;
      font-weight: 500;
      margin-bottom: 0.75rem;
      color: #e0e0e0;
    }

    .option-cards {
      display: grid;
      gap: 1rem;
    }

    .option-card {
      background: #2a2a2a;
      border: 2px solid #333;
      border-radius: 12px;
      padding: 1.25rem;
      cursor: pointer;
      transition: all 0.3s;
      position: relative;
    }

    .option-card:hover {
      border-color: #149dcc;
      transform: translateY(-2px);
    }

    .option-card.selected {
      border-color: #149dcc;
      background: rgba(20, 157, 204, 0.1);
    }

    .option-card.selected::after {
      content: '✓';
      position: absolute;
      top: 10px;
      right: 10px;
      width: 24px;
      height: 24px;
      background: #149dcc;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 14px;
      font-weight: bold;
    }

    .option-title {
      font-weight: 600;
      margin-bottom: 0.5rem;
      color: white;
    }

    .option-description {
      font-size: 0.9rem;
      color: #a0a0a0;
      margin-bottom: 0.75rem;
    }

    .option-price {
      color: #149dcc;
      font-weight: bold;
      font-size: 1.1rem;
    }

    .feature-checkbox {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
      padding: 1rem;
      background: #2a2a2a;
      border-radius: 8px;
      margin-bottom: 0.75rem;
      cursor: pointer;
      transition: all 0.2s;
    }

    .feature-checkbox:hover {
      background: #333;
    }

    .feature-checkbox.selected {
      background: rgba(20, 157, 204, 0.1);
      border: 1px solid #149dcc;
    }

    .checkbox-input {
      width: 20px;
      height: 20px;
      cursor: pointer;
      accent-color: #149dcc;
    }

    .feature-info {
      flex: 1;
    }

    .feature-name {
      font-weight: 500;
      margin-bottom: 0.25rem;
    }

    .feature-desc {
      font-size: 0.85rem;
      color: #a0a0a0;
    }

    .feature-cost {
      color: #149dcc;
      font-weight: 600;
      white-space: nowrap;
    }

    .slider-container {
      margin: 1.5rem 0;
    }

    .slider {
      width: 100%;
      height: 8px;
      border-radius: 4px;
      background: #333;
      outline: none;
      -webkit-appearance: none;
    }

    .slider::-webkit-slider-thumb {
      -webkit-appearance: none;
      appearance: none;
      width: 24px;
      height: 24px;
      border-radius: 50%;
      background: #149dcc;
      cursor: pointer;
      transition: all 0.2s;
    }

    .slider::-webkit-slider-thumb:hover {
      transform: scale(1.2);
    }

    .slider::-moz-range-thumb {
      width: 24px;
      height: 24px;
      border-radius: 50%;
      background: #149dcc;
      cursor: pointer;
      border: none;
    }

    .slider-value {
      display: flex;
      justify-content: space-between;
      margin-top: 0.5rem;
      font-size: 0.9rem;
      color: #a0a0a0;
    }

    .result-panel {
      background: linear-gradient(135deg, #149dcc 0%, #0d7a9e 100%);
      border-radius: 16px;
      padding: 2.5rem;
      color: white;
      text-align: center;
      position: sticky;
      top: 100px;
    }

    .result-label {
      font-size: 1.2rem;
      margin-bottom: 1rem;
      opacity: 0.9;
    }

    .result-price {
      font-size: 4rem;
      font-weight: bold;
      margin-bottom: 0.5rem;
      text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
    }

    .result-range {
      font-size: 1.1rem;
      opacity: 0.9;
      margin-bottom: 2rem;
    }

    .result-details {
      background: rgba(255,255,255,0.15);
      border-radius: 12px;
      padding: 1.5rem;
      margin-bottom: 2rem;
      text-align: left;
    }

    .detail-row {
      display: flex;
      justify-content: space-between;
      padding: 0.75rem 0;
      border-bottom: 1px solid rgba(255,255,255,0.1);
    }

    .detail-row:last-child {
      border-bottom: none;
    }

    .detail-label {
      opacity: 0.9;
    }

    .detail-value {
      font-weight: 600;
    }

    .cta-buttons {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .btn-primary-calc {
      background: white;
      color: #149dcc;
      border: none;
      padding: 1rem 2rem;
      border-radius: 50px;
      font-weight: 600;
      font-size: 1.1rem;
      cursor: pointer;
      transition: all 0.3s;
    }

    .btn-primary-calc:hover {
      transform: scale(1.05);
      box-shadow: 0 8px 20px rgba(0,0,0,0.3);
    }

    .btn-secondary-calc {
      background: transparent;
      color: white;
      border: 2px solid white;
      padding: 1rem 2rem;
      border-radius: 50px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s;
    }

    .btn-secondary-calc:hover {
      background: rgba(255,255,255,0.1);
    }

    .disclaimer {
      font-size: 0.85rem;
      opacity: 0.7;
      margin-top: 1rem;
      line-height: 1.6;
    }

    .timeline-estimate {
      background: rgba(255,255,255,0.1);
      border-radius: 12px;
      padding: 1.5rem;
      margin-top: 1.5rem;
    }

    .timeline-title {
      font-weight: 600;
      margin-bottom: 0.75rem;
    }

    .timeline-value {
      font-size: 1.5rem;
      font-weight: bold;
      color: #ffd700;
    }
  </style>
</head>
<body>

  <!-- NAVBAR -->
  <nav class="navbar navbar-expand-custom navbar-custom sticky-top">
    <div class="container">
      <a class="navbar-brand" href="index.html">Andrea Piani</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse justify-content-end" id="navbarNav">
          <li class="nav-item"><a class="nav-link" href="#" onclick="openServiziPopup(); return false;">Servizi ▾</a></li>
          <li class="nav-item"><a class="nav-link" href="progetti-open-source.html">Progetti</a></li>
          <li class="nav-item"><a class="nav-link active" href="price-calculator.html">Calcolatore</a></li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="calculator-container">
    <!-- Header -->
    <div class="calculator-header animate-fadeInUp">
      <h1>💰 Calcolatore Preventivo App</h1>
      <p style="font-size: 1.2rem; color: #a0a0a0; max-width: 700px; margin: 0 auto;">
        Ottieni una stima istantanea del costo e dei tempi di sviluppo della tua app personalizzata
      </p>
    </div>

    <div class="calculator-grid">
      <!-- Left Column - Options -->
      <div>
        <!-- Platform Selection -->
        <div class="calculator-section scroll-animate">
          <h3>📱 Piattaforma</h3>
          <div class="option-group">
            <div class="option-cards" id="platformOptions">
              <div class="option-card" data-platform="ios" data-multiplier="1">
                <div class="option-title">🍎 Solo iOS</div>
                <div class="option-description">iPhone e iPad</div>
                <div class="option-price">Base</div>
              </div>
              <div class="option-card" data-platform="android" data-multiplier="1">
                <div class="option-title">🤖 Solo Android</div>
                <div class="option-description">Smartphone e tablet Android</div>
                <div class="option-price">Base</div>
              </div>
              <div class="option-card selected" data-platform="both" data-multiplier="1.7">
                <div class="option-title">📱 iOS + Android</div>
                <div class="option-description">Entrambe le piattaforme (Cross-platform)</div>
                <div class="option-price">+70%</div>
              </div>
            </div>
          </div>
        </div>

        <!-- App Complexity -->
        <div class="calculator-section scroll-animate">
          <h3>⚙️ Complessità</h3>
          <div class="option-group">
            <div class="option-cards" id="complexityOptions">
              <div class="option-card" data-complexity="simple" data-base="8000">
                <div class="option-title">🟢 Semplice</div>
                <div class="option-description">3-5 schermate, funzionalità base</div>
                <div class="option-price">€8.000 - €15.000</div>
              </div>
              <div class="option-card selected" data-complexity="medium" data-base="20000">
                <div class="option-title">🟡 Media</div>
                <div class="option-description">8-15 schermate, funzionalità standard</div>
                <div class="option-price">€15.000 - €35.000</div>
              </div>
              <div class="option-card" data-complexity="complex" data-base="45000">
                <div class="option-title">🔴 Complessa</div>
                <div class="option-description">20+ schermate, funzionalità avanzate</div>
                <div class="option-price">€35.000 - €80.000+</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Features -->
        <div class="calculator-section scroll-animate">
          <h3>✨ Funzionalità Aggiuntive</h3>
          <div class="option-group">
            <div class="feature-checkbox" data-feature="auth" data-cost="2000">
              <input type="checkbox" class="checkbox-input">
              <div class="feature-info">
                <div class="feature-name">Login Social (Google, Apple, Facebook)</div>
                <div class="feature-desc">Autenticazione con servizi terzi</div>
              </div>
              <div class="feature-cost">+€2.000</div>
            </div>

            <div class="feature-checkbox" data-feature="payments" data-cost="4000">
              <input type="checkbox" class="checkbox-input">
              <div class="feature-info">
                <div class="feature-name">Pagamenti (Stripe, PayPal)</div>
                <div class="feature-desc">Gateway di pagamento integrati</div>
              </div>
              <div class="feature-cost">+€4.000</div>
            </div>

            <div class="feature-checkbox" data-feature="chat" data-cost="5000">
              <input type="checkbox" class="checkbox-input">
              <div class="feature-info">
                <div class="feature-name">Chat in Tempo Reale</div>
                <div class="feature-desc">Messaggistica istantanea</div>
              </div>
              <div class="feature-cost">+€5.000</div>
            </div>

            <div class="feature-checkbox" data-feature="maps" data-cost="3000">
              <input type="checkbox" class="checkbox-input">
              <div class="feature-info">
                <div class="feature-name">Mappe e Geolocalizzazione</div>
                <div class="feature-desc">GPS e mappe interattive</div>
              </div>
              <div class="feature-cost">+€3.000</div>
            </div>

            <div class="feature-checkbox" data-feature="push" data-cost="1500">
              <input type="checkbox" class="checkbox-input">
              <div class="feature-info">
                <div class="feature-name">Notifiche Push</div>
                <div class="feature-desc">Notifiche per iOS e Android</div>
              </div>
              <div class="feature-cost">+€1.500</div>
            </div>

            <div class="feature-checkbox" data-feature="backend" data-cost="8000">
              <input type="checkbox" class="checkbox-input">
              <div class="feature-info">
                <div class="feature-name">Backend Custom</div>
                <div class="feature-desc">API REST, database, admin panel</div>
              </div>
              <div class="feature-cost">+€8.000</div>
            </div>

            <div class="feature-checkbox" data-feature="ai" data-cost="10000">
              <input type="checkbox" class="checkbox-input">
              <div class="feature-info">
                <div class="feature-name">AI / Machine Learning</div>
                <div class="feature-desc">Funzionalità intelligenti</div>
              </div>
              <div class="feature-cost">+€10.000</div>
            </div>
          </div>
        </div>

        <!-- Design Level -->
        <div class="calculator-section scroll-animate">
          <h3>🎨 Livello Design</h3>
          <div class="option-group">
            <label class="option-label">
              Quanto importante è il design?
              <span id="designValue" style="float: right; color: #149dcc; font-weight: 600;">Standard</span>
            </label>
            <input type="range" class="slider" id="designSlider" min="0" max="2" value="1" step="1">
            <div class="slider-value">
              <span>Template</span>
              <span>Standard</span>
              <span>Premium</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Right Column - Results -->
      <div>
        <div class="result-panel scroll-animate">
          <div class="result-label">Stima Totale</div>
          <div class="result-price" id="totalPrice">€20.000</div>
          <div class="result-range" id="priceRange">Range: €18.000 - €24.000</div>

          <div class="result-details">
            <div class="detail-row">
              <span class="detail-label">Base:</span>
              <span class="detail-value" id="basePrice">€20.000</span>
            </div>
            <div class="detail-row">
              <span class="detail-label">Funzionalità extra:</span>
              <span class="detail-value" id="featuresPrice">€0</span>
            </div>
            <div class="detail-row">
              <span class="detail-label">Design:</span>
              <span class="detail-value" id="designPrice">Incluso</span>
            </div>
            <div class="detail-row">
              <span class="detail-label">Piattaforma:</span>
              <span class="detail-value" id="platformInfo">iOS + Android</span>
            </div>
          </div>

          <div class="timeline-estimate">
            <div class="timeline-title">⏱️ Tempo Stimato</div>
            <div class="timeline-value" id="timelineValue">8-12 settimane</div>
          </div>

          <div class="cta-buttons">
            <button class="btn-primary-calc" onclick="requestQuote()">
              📞 Richiedi Preventivo Dettagliato
            </button>
            <a href="https://wa.me/393516248936?text=Ho%20calcolato%20un%20preventivo%20sul%20sito" target="_blank" class="btn-secondary-calc" style="text-decoration: none; display: block;">
              💬 Contattami su WhatsApp
            </a>
          </div>

          <div class="disclaimer">
            * Questa è una stima approssimativa. Il costo finale dipende da requisiti specifici, integrazioni e complessità del progetto.
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="assets/bootstrap/js/bootstrap.bundle.min.js"></script>
  <script src="utilities.js"></script>
  <script src="dark-mode.js"></script>
  <script src="animations.js"></script>

  <script>
    // Calculator Logic
    let selectedPlatform = 'both';
    let selectedComplexity = 'medium';
    let platformMultiplier = 1.7;
    let basePrice = 20000;
    let features = [];
    let designLevel = 1;

    const designMultipliers = [1, 1, 1.3]; // Template, Standard, Premium
    const designLabels = ['Template', 'Standard', 'Premium'];
    const timeEstimates = {
      simple: '4-6 settimane',
      medium: '8-12 settimane',
      complex: '16-24 settimane'
    };

    // Platform Selection
    document.querySelectorAll('#platformOptions .option-card').forEach(card => {
      card.addEventListener('click', function() {
        document.querySelectorAll('#platformOptions .option-card').forEach(c => c.classList.remove('selected'));
        this.classList.add('selected');
        selectedPlatform = this.dataset.platform;
        platformMultiplier = parseFloat(this.dataset.multiplier);
        calculate();
      });
    });

    // Complexity Selection
    document.querySelectorAll('#complexityOptions .option-card').forEach(card => {
      card.addEventListener('click', function() {
        document.querySelectorAll('#complexityOptions .option-card').forEach(c => c.classList.remove('selected'));
        this.classList.add('selected');
        selectedComplexity = this.dataset.complexity;
        basePrice = parseInt(this.dataset.base);
        calculate();
      });
    });

    // Features Selection
    document.querySelectorAll('.feature-checkbox').forEach(feature => {
      feature.addEventListener('click', function() {
        const checkbox = this.querySelector('.checkbox-input');
        checkbox.checked = !checkbox.checked;
        this.classList.toggle('selected', checkbox.checked);

        const cost = parseInt(this.dataset.cost);
        const featureName = this.dataset.feature;

        if (checkbox.checked) {
          features.push({ name: featureName, cost: cost });
        } else {
          features = features.filter(f => f.name !== featureName);
        }

        calculate();
      });
    });

    // Design Slider
    const designSlider = document.getElementById('designSlider');
    const designValue = document.getElementById('designValue');

    designSlider.addEventListener('input', function() {
      designLevel = parseInt(this.value);
      designValue.textContent = designLabels[designLevel];
      calculate();
    });

    // Calculate Price
    function calculate() {
      // Base price with platform multiplier
      let total = basePrice * platformMultiplier;

      // Add features
      const featuresTotal = features.reduce((sum, f) => sum + f.cost, 0);
      total += featuresTotal;

      // Apply design multiplier
      total *= designMultipliers[designLevel];

      // Round to nearest 1000
      total = Math.round(total / 1000) * 1000;

      // Calculate range (+/- 15%)
      const rangeMin = Math.round(total * 0.85 / 1000) * 1000;
      const rangeMax = Math.round(total * 1.15 / 1000) * 1000;

      // Update UI
      document.getElementById('totalPrice').textContent = '€' + total.toLocaleString();
      document.getElementById('priceRange').textContent = `Range: €${rangeMin.toLocaleString()} - €${rangeMax.toLocaleString()}`;
      document.getElementById('basePrice').textContent = '€' + (basePrice * platformMultiplier).toLocaleString();
      document.getElementById('featuresPrice').textContent = featuresTotal > 0 ? '€' + featuresTotal.toLocaleString() : '€0';

      const designCost = (basePrice * platformMultiplier * (designMultipliers[designLevel] - 1)).toFixed(0);
      document.getElementById('designPrice').textContent = designLevel > 1 ? '+€' + parseInt(designCost).toLocaleString() : 'Incluso';

      document.getElementById('platformInfo').textContent =
        selectedPlatform === 'ios' ? 'Solo iOS' :
        selectedPlatform === 'android' ? 'Solo Android' :
        'iOS + Android';

      document.getElementById('timelineValue').textContent = timeEstimates[selectedComplexity];

      // Track event
      if (window.AppUtils) {
        AppUtils.trackEvent('Calculator', 'PriceCalculated', total.toString());
      }
    }

    function requestQuote() {
      const message = `Ciao Andrea! Ho calcolato un preventivo sul sito:

🔹 Piattaforma: ${selectedPlatform === 'ios' ? 'iOS' : selectedPlatform === 'android' ? 'Android' : 'iOS + Android'}
🔹 Complessità: ${selectedComplexity}
🔹 Funzionalità: ${features.length} extra
🔹 Stima: ${document.getElementById('totalPrice').textContent}

Vorrei discutere il progetto in dettaglio.`;

      const encoded = encodeURIComponent(message);
      window.open(`https://wa.me/393516248936?text=${encoded}`, '_blank');

      if (window.AppUtils) {
        AppUtils.trackEvent('Calculator', 'QuoteRequested', document.getElementById('totalPrice').textContent);
      }
    }

    // Initial calculation
    calculate();
  </script>

<!-- Andrea AI Chat Widget -->
<script src="assets/js/chat-backend.js" defer data-aai-backend="1"></script>
<script src="assets/js/chat-widget.js" defer data-aai-js="1"></script>
</body>
</html>
