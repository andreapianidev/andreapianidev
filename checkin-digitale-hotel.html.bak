  <script src="animations.js"></script>
  <script>
    // Osserva anche reveal-left/right/zoom e stagger (oltre a scroll-animate già gestito)
    (function(){
      const els = document.querySelectorAll('.reveal-left, .reveal-right, .reveal-zoom, .stagger');
      if (!els.length) return;
      const obs = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
      els.forEach(el => {
        // Elementi above-the-fold: rendi subito visibili
        const rect = el.getBoundingClientRect();
        if (rect.top < window.innerHeight && rect.bottom > 0) {
          el.classList.add('visible');
        } else {
          obs.observe(el);
        }
      });
    })();

    // Counter animati ROI
    (function(){
      const counters = document.querySelectorAll('.stat-roi .num[data-count]');
      if (!counters.length) return;
      const animate = (el) => {
        const target = parseFloat(el.dataset.count);
        const divide = parseFloat(el.dataset.divide || 1);
        const prefix = el.dataset.prefix || '';
        const suffix = el.dataset.suffix || '';
        const duration = 1600;
        const start = performance.now();
        const ease = (t) => 1 - Math.pow(1 - t, 3);
        const tick = (now) => {
          const p = Math.min((now - start) / duration, 1);
          const v = target * ease(p);
          const display = divide > 1 ? (v / divide).toFixed(1) : Math.round(v).toLocaleString('it-IT');
          el.textContent = prefix + display + suffix;
          if (p < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      };
      const obs = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) { animate(e.target); obs.unobserve(e.target); }
        });
      }, { threshold: 0.4 });
      counters.forEach(c => obs.observe(c));
    })();
  </script>
