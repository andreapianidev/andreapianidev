  <style>
    body { background: #0a0a0a; color: #fff; }
    .navbar-custom { background: #000; border-bottom: 1px solid #333; }
    .navbar-custom a { color: #fff !important; }
    .navbar-custom a:hover { color: #149dcc !important; }
    .hero-gradient { background: linear-gradient(135deg, #149dcc 0%, #0d7a9e 50%, #0a5a78 100%); }
    .btn-primary-custom { background: linear-gradient(135deg, #149dcc 0%, #0d7a9e 100%); border: none; color: white; }
    .btn-primary-custom:hover { transform: translateY(-2px); box-shadow: 0 10px 30px rgba(20,157,204,0.4); }
    .feature-card { background: linear-gradient(135deg, #1a1a1a 0%, #1f2d3a 100%); border: 1px solid #149dcc; }
    .tech-badge { background: rgba(20,157,204,0.2); border: 1px solid #149dcc; }
    .screenshot-shadow { box-shadow: 0 20px 60px rgba(20,157,204,0.3); }
    .rating-stars { color: #ffc107; }
    .link-back:hover { color: #149dcc !important; }
    .normativa-box { background: linear-gradient(135deg, #1e3a2b 0%, #2d5a3d 100%); border-left: 4px solid #4caf50; }

    /* ===== ANIMAZIONI AVANZATE LANDING CHECKIN ===== */
    @keyframes floatPhone {
      0%, 100% { transform: translateY(0) rotate(0deg); }
      50%      { transform: translateY(-18px) rotate(-1.5deg); }
    }
    @keyframes gradientShift {
      0%, 100% { background-position: 0% 50%; }
      50%      { background-position: 100% 50%; }
    }
    @keyframes shimmer {
      0%   { background-position: -1000px 0; }
      100% { background-position: 1000px 0; }
    }
    @keyframes glowPulse {
      0%, 100% { box-shadow: 0 0 0 0 rgba(20,157,204,0.55), 0 20px 60px rgba(20,157,204,0.25); }
      50%      { box-shadow: 0 0 0 18px rgba(20,157,204,0), 0 20px 60px rgba(20,157,204,0.45); }
    }
    @keyframes honeyDrip {
      0%   { transform: translateY(-8px) scaleY(0.9); opacity: 0.35; }
      50%  { transform: translateY(4px)  scaleY(1.15); opacity: 0.85; }
      100% { transform: translateY(-8px) scaleY(0.9); opacity: 0.35; }
    }
    @keyframes popBadge {
      0%   { transform: scale(0.7); opacity: 0; }
      70%  { transform: scale(1.1); opacity: 1; }
      100% { transform: scale(1); }
    }
    @keyframes ring {
      0%   { box-shadow: 0 0 0 0 rgba(76,175,80,0.65); }
      70%  { box-shadow: 0 0 0 18px rgba(76,175,80,0); }
      100% { box-shadow: 0 0 0 0 rgba(76,175,80,0); }
    }
    @keyframes slideInLeftSoft {
      from { opacity: 0; transform: translateX(-40px); }
      to   { opacity: 1; transform: translateX(0); }
    }
    @keyframes slideInRightSoft {
      from { opacity: 0; transform: translateX(40px); }
      to   { opacity: 1; transform: translateX(0); }
    }
    @keyframes fadeZoom {
      from { opacity: 0; transform: scale(0.94); }
      to   { opacity: 1; transform: scale(1); }
    }

    .app-mockup {
      animation: floatPhone 6s ease-in-out infinite, glowPulse 4s ease-in-out infinite;
      will-change: transform, box-shadow;
    }
    .hero-gradient {
      background-size: 200% 200%;
      animation: gradientShift 14s ease infinite;
    }
    .btn-primary-custom {
      position: relative;
      overflow: hidden;
      transition: transform .35s cubic-bezier(.2,.9,.3,1.2), box-shadow .35s ease;
    }
    .btn-primary-custom::after {
      content: "";
      position: absolute; inset: 0;
      background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.35) 50%, transparent 100%);
      background-size: 1000px 100%;
      animation: shimmer 3.5s infinite linear;
      pointer-events: none;
      mix-blend-mode: overlay;
    }
    .feature-card {
      transition: transform .4s cubic-bezier(.2,.9,.3,1.2), border-color .3s, box-shadow .4s;
      will-change: transform;
    }
    .feature-card:hover {
      transform: translateY(-8px) rotateX(2deg) rotateY(-2deg);
      border-color: #2bc3f5 !important;
      box-shadow: 0 25px 60px rgba(20,157,204,0.35);
    }
    .tech-badge { transition: transform .3s ease, background .3s ease; }
    .tech-badge:hover { transform: translateY(-4px) scale(1.05); background: rgba(20,157,204,0.35); }

    /* Scroll reveal utility (si basa su .scroll-animate già in animations.css) */
    .reveal-left  { opacity: 0; transform: translateX(-40px); transition: opacity .9s ease, transform .9s ease; }
    .reveal-right { opacity: 0; transform: translateX(40px);  transition: opacity .9s ease, transform .9s ease; }
    .reveal-zoom  { opacity: 0; transform: scale(.94);        transition: opacity .9s ease, transform .9s ease; }
    .reveal-left.visible, .reveal-right.visible, .reveal-zoom.visible { opacity: 1; transform: none; }

    /* Stagger children */
    .stagger > * { opacity: 0; transform: translateY(20px); transition: opacity .7s ease, transform .7s ease; }
    .stagger.visible > * { opacity: 1; transform: none; }
    .stagger.visible > *:nth-child(1) { transition-delay: .05s; }
    .stagger.visible > *:nth-child(2) { transition-delay: .15s; }
    .stagger.visible > *:nth-child(3) { transition-delay: .25s; }
    .stagger.visible > *:nth-child(4) { transition-delay: .35s; }
    .stagger.visible > *:nth-child(5) { transition-delay: .45s; }
    .stagger.visible > *:nth-child(6) { transition-delay: .55s; }

    /* Hero badge pop */
    .hero-badge-pop { animation: popBadge .9s cubic-bezier(.2,.9,.3,1.4) both; }

    /* Live dot */
    .live-dot {
      display: inline-block; width: 10px; height: 10px; border-radius: 50%;
      background: #4caf50; margin-right: 6px; animation: ring 2s infinite;
    }

    /* Honey-themed accent (metafora "api sul miele") */
    .honey-section {
      position: relative;
      background: radial-gradient(ellipse at top, #2a1a05 0%, #0a0a0a 60%);
      overflow: hidden;
    }
    .honey-section::before {
      content: "";
      position: absolute; inset: 0;
      background-image:
        radial-gradient(circle at 20% 30%, rgba(255,193,7,0.08) 0%, transparent 40%),
        radial-gradient(circle at 80% 70%, rgba(255,152,0,0.06) 0%, transparent 45%);
      pointer-events: none;
    }
    .honey-card {
      background: linear-gradient(135deg, #1a1208 0%, #2a1d08 100%);
      border: 1px solid rgba(255,193,7,0.3);
      border-radius: 16px;
      padding: 1.8rem;
      transition: transform .4s cubic-bezier(.2,.9,.3,1.2), box-shadow .4s, border-color .3s;
      height: 100%;
    }
    .honey-card:hover {
      transform: translateY(-6px);
      border-color: #ffc107;
      box-shadow: 0 20px 50px rgba(255,193,7,0.2);
    }
    .honey-drop {
      display: inline-block;
      animation: honeyDrip 3s ease-in-out infinite;
    }

    /* Counter ROI */
    .stat-roi {
      background: linear-gradient(135deg, #0d2d4a 0%, #122a3d 100%);
      border: 1px solid rgba(20,157,204,0.4);
      border-radius: 18px;
      padding: 2rem 1.5rem;
      text-align: center;
      transition: transform .35s ease, border-color .35s ease;
    }
    .stat-roi:hover { transform: translateY(-6px); border-color: #149dcc; }
    .stat-roi .num {
      font-size: 3rem; font-weight: 900;
      background: linear-gradient(90deg, #ffc107 0%, #149dcc 100%);
      -webkit-background-clip: text; background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    /* Timeline "giornata tipo" */
    .timeline-item {
      position: relative;
      padding: 1.2rem 1.2rem 1.2rem 3.5rem;
      border-left: 2px solid rgba(20,157,204,0.3);
      margin-left: 1rem;
    }
    .timeline-item::before {
      content: "";
      position: absolute; left: -11px; top: 1.4rem;
      width: 20px; height: 20px; border-radius: 50%;
      background: linear-gradient(135deg, #149dcc, #0ea5e9);
      box-shadow: 0 0 0 4px #0a0a0a, 0 0 15px rgba(20,157,204,0.5);
    }

    @media (prefers-reduced-motion: reduce) {
      .app-mockup, .hero-gradient, .btn-primary-custom::after, .honey-drop, .live-dot { animation: none !important; }
    }

    /* Failsafe: se JS è disabilitato o fallisce, mostra comunque il contenuto dopo poco */
    @keyframes forceReveal { to { opacity: 1; transform: none; } }
    .reveal-left, .reveal-right, .reveal-zoom {
      animation: forceReveal 0.01s linear 2.5s forwards;
    }
    .stagger > * {
      animation: forceReveal 0.01s linear 2.5s forwards;
    }
    noscript .reveal-left, noscript .reveal-right, noscript .reveal-zoom { opacity: 1 !important; transform: none !important; }
  </style>
</head>
