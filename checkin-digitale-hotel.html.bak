  <!-- HERO SECTION -->
  <section class="hero-gradient" style="padding: 5rem 0; color: white;">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-lg-6 reveal-left">
          <span class="hero-badge-pop" style="background: rgba(255,255,255,0.2); padding: 0.5rem 1rem; border-radius: 25px; font-size: 0.9rem;"><span class="live-dot"></span>SaaS Live &mdash; Usato da 500+ strutture ricettive in Italia</span>
          <h1 class="display-3 mt-3 mb-3"><strong>CheckIn Facile</strong></h1>
          <h2 class="h3 mb-4" style="opacity: 0.95;">Il <strong>Software Check-in Online</strong> per Hotel, B&amp;B, Case Vacanze, Affittacamere e Agriturismi in Italia</h2>
          <p class="lead mb-3">Il <strong><a href="gestionali-personalizzati.html" style="color:#fff;">gestionale all-in-one</a></strong> che trasforma la <strong>registrazione ospiti</strong> della tua struttura ricettiva in un processo automatico, elegante e 100% conforme alla legge. Invia in automatico le <strong>schedine alla Questura via Alloggiati Web</strong>, calcola e incassa la <strong>tassa di soggiorno</strong>, sincronizza le prenotazioni di <strong>Booking.com e Airbnb</strong>, apre le porte con <strong>smart lock Nuki</strong> e risponde agli ospiti 24/7 con una <strong>reception virtuale AI multilingua</strong>.</p>
          <p class="mb-4" style="opacity: 0.95;">Pensato per <strong>proprietari di case vacanza, gestori di B&amp;B, host Airbnb professionali, titolari di affittacamere, agriturismi e piccoli hotel</strong> che vogliono <strong>risparmiare fino a 15 ore a settimana</strong>, eliminare la burocrazia manuale, evitare le <strong>sanzioni del Decreto Sicurezza 2026</strong> (fino a €5.000 per ospite non comunicato) e offrire agli ospiti un'esperienza di <strong>self check-in digitale</strong> degna di una catena 5 stelle. Conforme GDPR, server in Europa, attivazione in 48 ore.</p>
          
          <div class="d-flex flex-wrap gap-3 mb-4">
            <a href="https://checkinfacile.com" target="_blank" rel="noopener" class="btn btn-primary-custom btn-lg" style="padding: 1rem 2rem; font-weight: 600; border-radius: 50px;">
              🚀 Prova la Demo
            </a>
            <a href="https://wa.me/393516248936?text=Ciao%2C%20vorrei%20info%20su%20CheckIn%20Facile" target="_blank" class="btn btn-outline-light btn-lg" style="padding: 1rem 2rem; border-radius: 50px;">
              💬 Parla con lo Sviluppatore
            </a>
          </div>

          <div class="d-flex align-items-center gap-4 flex-wrap mb-3">
            <div><span class="rating-stars">⭐⭐⭐⭐⭐</span> <strong>4.9/5</strong> (127 recensioni)</div>
            <div style="opacity: 0.9;">✅ Conforme Decreto 2026</div>
            <div style="opacity: 0.9;">🔒 GDPR Compliant</div>
          </div>

          <!-- Stats reali -->
          <div class="d-flex gap-4 flex-wrap mt-3">
            <div style="background: rgba(255,255,255,0.15); padding: 0.8rem 1.2rem; border-radius: 12px; text-align: center;">
              <div style="font-size: 1.8rem; font-weight: 800;">98%</div>
              <div style="font-size: 0.8rem; opacity: 0.9;">Tempo risparmiato</div>
            </div>
            <div style="background: rgba(255,255,255,0.15); padding: 0.8rem 1.2rem; border-radius: 12px; text-align: center;">
              <div style="font-size: 1.8rem; font-weight: 800;">24/7</div>
              <div style="font-size: 0.8rem; opacity: 0.9;">Check-in autonomo</div>
            </div>
            <div style="background: rgba(255,255,255,0.15); padding: 0.8rem 1.2rem; border-radius: 12px; text-align: center;">
              <div style="font-size: 1.8rem; font-weight: 800;">500+</div>
              <div style="font-size: 0.8rem; opacity: 0.9;">Strutture attive</div>
            </div>
          </div>
        </div>
        <div class="col-lg-6 mt-5 mt-lg-0 reveal-right">
          <div style="position: relative;">
            <!-- MOCKUP APP MOBILE CHECKIN -->
            <div class="app-mockup" style="background: linear-gradient(135deg, #0f2027 0%, #203a43 50%, #2c5364 100%); border-radius: 30px; border: 4px solid rgba(20,157,204,0.5); overflow: hidden; box-shadow: 0 25px 80px rgba(20,157,204,0.4); max-width: 320px; margin: 0 auto;">
              <!-- Phone Header -->
              <div style="background: linear-gradient(90deg, #149dcc 0%, #0ea5e9 100%); padding: 12px 20px; display: flex; align-items: center; justify-content: center; position: relative;">
                <div style="width: 80px; height: 20px; background: rgba(0,0,0,0.3); border-radius: 10px;"></div>
              </div>
              <!-- App Content -->
              <div style="padding: 25px 20px;">
                <!-- Hotel Name -->
                <div style="text-align: center; margin-bottom: 25px;">
                  <div style="font-size: 20px; margin-bottom: 5px;">🏨</div>
                  <div style="color: #149dcc; font-weight: bold; font-size: 16px;">Hotel Bella Vista</div>
                  <div style="color: #888; font-size: 11px;">Check-In Digitale</div>
                </div>
                <!-- Progress Steps -->
                <div style="display: flex; justify-content: space-between; margin-bottom: 25px; padding: 0 10px;">
                  <div style="text-align: center;">
                    <div style="width: 36px; height: 36px; background: #4caf50; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 5px; font-size: 16px;">📄</div>
                    <div style="font-size: 9px; color: #4caf50;">Dati</div>
                  </div>
                  <div style="text-align: center;">
                    <div style="width: 36px; height: 36px; background: #149dcc; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 5px; font-size: 16px;">🆔</div>
                    <div style="font-size: 9px; color: #149dcc;">Documento</div>
                  </div>
                  <div style="text-align: center;">
                    <div style="width: 36px; height: 36px; background: rgba(255,255,255,0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 5px; font-size: 16px;">✍️</div>
                    <div style="font-size: 9px; color: #888;">Firma</div>
                  </div>
                </div>
                <!-- ID Scanner -->
                <div style="background: rgba(20,157,204,0.1); border: 2px dashed rgba(20,157,204,0.5); border-radius: 12px; padding: 30px 20px; text-align: center; margin-bottom: 20px;">
                  <div style="font-size: 40px; margin-bottom: 10px;">📷</div>
                  <div style="color: #149dcc; font-weight: 600; font-size: 13px; margin-bottom: 5px;">Scannerizza Documento</div>
                  <div style="color: #888; font-size: 11px;">Carta d'identità o Passaporto</div>
                </div>
                <!-- Guest Preview -->
