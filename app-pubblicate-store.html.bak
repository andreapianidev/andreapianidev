    }
    .navbar-custom a {
      color: #ffffff !important;
      margin: 0 1rem;
      font-weight: 500;
      text-decoration: none;
    }
    .navbar-custom a:hover { color: #149dcc !important; }
    .navbar-custom .active { color: #149dcc !important; }
    .navbar-brand {
      color: #149dcc !important;
      font-weight: bold;
      font-size: 1.5rem;
    }
    .hero-appstore {
      background: linear-gradient(135deg, #149dcc 0%, #0d7a9e 100%);
      padding: 5rem 0;
      color: white;
      text-align: center;
    }
    .hero-appstore h1 {
      font-size: 3.5rem;
      font-weight: bold;
      margin-bottom: 1rem;
    }
    .hero-appstore p {
      font-size: 1.3rem;
      margin-bottom: 2rem;
    }
    .app-card {
      background: #1a1a1a;
      border: 1px solid #333;
      border-radius: 15px;
      padding: 2rem;
      height: 100%;
      transition: all 0.3s;
      position: relative;
    }
    .app-card:hover {
      transform: translateY(-5px);
      border-color: #149dcc;
      box-shadow: 0 10px 30px rgba(20, 157, 204, 0.3);
    }
    .app-icon {
      width: 80px;
      height: 80px;
      border-radius: 18px;
      margin-bottom: 1.5rem;
      box-shadow: 0 4px 10px rgba(0,0,0,0.3);
    }
    .app-title {
      font-size: 1.5rem;
      font-weight: bold;
      color: #149dcc;
      margin-bottom: 0.8rem;
    }
    .app-category {
      display: inline-block;
      padding: 0.4rem 1rem;
      border-radius: 20px;
      font-size: 0.85rem;
      font-weight: 500;
      margin-bottom: 1rem;
      background: #149dcc;
      color: white;
    }
    .app-description {
      color: #cccccc;
      font-size: 1rem;
      margin-bottom: 1.5rem;
      line-height: 1.6;
    }
    .app-platforms {
      color: #999;
      font-size: 0.9rem;
      margin-bottom: 1rem;
    }
    .app-price {
      font-size: 1.2rem;
      font-weight: bold;
      color: #149dcc;
      margin-bottom: 1.5rem;
    }
    .appstore-btn {
      background: #000000;
      color: white;
      padding: 0.8rem 1.5rem;
      border-radius: 8px;
      text-decoration: none;
      display: inline-block;
      font-weight: 500;
      transition: 0.3s;
      border: 1px solid #149dcc;
    }
    .appstore-btn:hover {
      background: #149dcc;
      color: white;
      transform: translateY(-2px);
    }
    .stats-section {
      background: #0a0a0a;
      padding: 3rem 0;
      text-align: center;
    }
    .stat-box {
      background: #1a1a1a;
      border: 1px solid #333;
      border-radius: 10px;
      padding: 2rem;
    }
    .stat-number {
      font-size: 3rem;
      font-weight: bold;
      color: #149dcc;
    }
    .stat-label {
      font-size: 1.1rem;
      color: #cccccc;
      margin-top: 0.5rem;
    }
  </style>
</head>

